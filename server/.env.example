# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://brainphone_user:CHANGEME@rc1a-xxxx.mdb.yandexcloud.net:6432/brainphone_db?sslmode=require

# ─── TOTP Encryption ─────────────────────────────────────────────────────────
# Single key (initial setup):  openssl rand -base64 32
TOTP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_-base64_32

# Multi-key rotation mode (uncomment when rotating keys):
# TOTP_ENCRYPTION_KEYS=v1:<old-base64-key>,v2:<new-base64-key>
# TOTP_ENCRYPTION_KEY_ACTIVE=v2

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Секрет для подписи промежуточных auth-cookie (totp_pending). Если не задан —
# выводится из TOTP_ENCRYPTION_KEY. В проде лучше задать явно: openssl rand -base64 32
# AUTH_COOKIE_SECRET=

# CA-сертификат managed PostgreSQL (Yandex Cloud). Путь к .crt внутри контейнера.
# Если не задан — TLS к БД НЕ проверяется (риск MITM). Получить:
#   https://storage.yandexcloud.net/cloud-certs/CA.pem
# DB_CA_CERT=/app/certs/yandex-ca.pem
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://brainphone-frontend.website.yandexcloud.net

# ─── SMTP (email notifications) ───────────────────────────────────────────────
# Required in production; optional in development (emails queue but not sent)
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@yourdomain.ru
# SMTP_PASSWORD=<smtp-app-password>
# SMTP_FROM=BrainPhone <noreply@yourdomain.ru>

# ─── Redis (optional — falls back to PostgreSQL if not set) ──────────────────
# Yandex Managed Redis: rediss:// with TLS
# REDIS_URL=rediss://:password@rc1a-xxxx.mdb.yandexcloud.net:6380/0

# ─── Admin seeder (used ONLY with: npm run seed:admin) ────────────────────────
# Remove from env after seeding. Never commit to VCS.
SEED_ADMIN_EMAIL=admin@hospital.ru
SEED_ADMIN_PASSWORD=

# ─── Yandex Object Storage ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=brainphone-audio
S3_PHOTO_BUCKET_NAME=brainphone-photos

# ─── HaveIBeenPwned check (set to 'false' to disable in air-gapped env) ──────
HIBP_CHECK_ENABLED=true
